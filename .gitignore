# Dependencies
node_modules/

# Build output
out/
dist/
*.tgz

# Bun
.bun/
# bun.lock is committed for reproducible installs (pins exact dep versions)

# TypeScript
*.tsbuildinfo
*.d.ts.map

# Test coverage
coverage/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets
.env
.env.*
!.env.example

# Caches
.eslintcache
.cache/
.parcel-cache/

# Runtime data (generated by the app, user-specific)
# SQLite DB lives at ~/.local/share/leettui/ — not in the repo
*.db
*.db-shm
*.db-wal
*.sqlite

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Compiled binary (bun build --compile) + any local gzip-asset measurement
/leettui
/leettui.exe
/leettui.gz

# Claude Code skills (local-only, not shared via repo)
.claude/skills/*
# ...except project-specific skills that belong in the repo
!.claude/skills/release/

# Machine-specific Claude/GSD local settings (hardcoded paths; regenerated per machine)
.claude/settings.local.json
